<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Tema claro fijo: la app no cambia con el modo oscuro del sistema. -->
    <style name="Theme.WiFiBattleShip" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/univalle_red</item>
        <item name="colorPrimaryVariant">@color/univalle_red_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:statusBarColor">@color/univalle_red</item>
        <item name="android:forceDarkAllowed" tools:targetApi="q">false</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.WiFiBattleShip.Dialog</item>
    </style>

    <!-- Diálogos de marca: tarjeta redondeada, título navy, acción principal en rojo. -->
    <style name="ThemeOverlay.WiFiBattleShip.Dialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.WiFiBattleShip.Dialog</item>
        <item name="materialAlertDialogTitleTextStyle">@style/TextAppearance.WiFiBattleShip.DialogTitle</item>
        <item name="materialAlertDialogBodyTextStyle">@style/TextAppearance.WiFiBattleShip.DialogBody</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.WiFiBattleShip.DialogButton.Positive</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.WiFiBattleShip.DialogButton.Negative</item>
    </style>

    <style name="ShapeAppearance.WiFiBattleShip.Dialog" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">14dp</item>
    </style>

    <style name="TextAppearance.WiFiBattleShip.DialogTitle" parent="MaterialAlertDialog.MaterialComponents.Title.Text">
        <item name="android:textColor">@color/navy</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">18sp</item>
    </style>

    <style name="TextAppearance.WiFiBattleShip.DialogBody" parent="MaterialAlertDialog.MaterialComponents.Body.Text">
        <item name="android:textColor">@color/text_muted</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="Widget.WiFiBattleShip.DialogButton.Positive" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/univalle_red</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">10dp</item>
    </style>

    <style name="Widget.WiFiBattleShip.DialogButton.Negative" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/text_muted</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
    </style>

</resources>
