<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/menuFragment">

    <fragment
        android:id="@+id/menuFragment"
        android:name="com.wifibattleship.ui.fragments.MenuFragment"
        android:label="@string/app_name"
        tools:layout="@layout/fragment_menu">
        <action
            android:id="@+id/action_menuFragment_to_lobbyFragment"
            app:destination="@id/lobbyFragment" />
        <action
            android:id="@+id/action_menuFragment_to_settingsFragment"
            app:destination="@id/settingsFragment" />
    </fragment>

    <fragment
        android:id="@+id/lobbyFragment"
        android:name="com.wifibattleship.ui.fragments.LobbyFragment"
        android:label="@string/lobby"
        tools:layout="@layout/fragment_lobby">
        <argument
            android:name="connectionType"
            app:argType="string" />
        <action
            android:id="@+id/action_lobbyFragment_to_shipPlacementFragment"
            app:destination="@id/shipPlacementFragment" />
    </fragment>

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.wifibattleship.ui.fragments.SettingsFragment"
        android:label="@string/configuracion"
        tools:layout="@layout/fragment_settings" />

    <fragment
        android:id="@+id/shipPlacementFragment"
        android:name="com.wifibattleship.ui.fragments.ShipPlacementFragment"
        android:label="@string/coloca_tus_barcos"
        tools:layout="@layout/fragment_ship_placement">
        <action
            android:id="@+id/action_shipPlacementFragment_to_gameFragment"
            app:destination="@id/gameFragment" />
    </fragment>

    <fragment
        android:id="@+id/gameFragment"
        android:name="com.wifibattleship.ui.fragments.GameFragment"
        android:label="@string/juego"
        tools:layout="@layout/fragment_game">
        <action
            android:id="@+id/action_gameFragment_to_resultFragment"
            app:destination="@id/resultFragment"
            app:popUpTo="@id/shipPlacementFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/resultFragment"
        android:name="com.wifibattleship.ui.fragments.ResultFragment"
        android:label="@string/resultado"
        tools:layout="@layout/fragment_result">
        <argument
            android:name="winner"
            app:argType="string" />
        <action
            android:id="@+id/action_resultFragment_to_menuFragment"
            app:destination="@id/menuFragment"
            app:popUpTo="@id/menuFragment"
            app:popUpToInclusive="true" />
    </fragment>

</navigation>
