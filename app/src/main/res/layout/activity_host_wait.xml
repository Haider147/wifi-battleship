<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_grid"
    android:orientation="vertical">

    <!-- Franja roja de marca -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/univalle_red"
        android:fitsSystemWindows="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingTop="10dp"
        android:paddingEnd="20dp"
        android:paddingBottom="14dp">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:contentDescription="@string/app_name"
            android:src="@drawable/logo_app" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/role_host"
                android:textColor="@color/white"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:text="@string/host_sub"
                android:textColor="#D9FFFFFF"
                android:textSize="11sp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Contenido -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="16dp"
        android:paddingEnd="20dp">

        <!-- Tarjeta de pasos -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_cell_normal"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Paso 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <FrameLayout
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginTop="1dp">

                    <TextView
                        android:id="@+id/tvIcon1"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:background="@drawable/bg_step_pending"
                        android:gravity="center"
                        android:text="1"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <ProgressBar
                        android:id="@+id/pbStep1"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:indeterminateTint="@color/univalle_red"
                        android:visibility="gone" />

                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvStep1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/host_step1"
                        android:textColor="@color/text_muted_light"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/host_step1_desc"
                        android:textColor="@color/text_muted"
                        android:textSize="11.5sp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Paso 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal">

                <FrameLayout
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginTop="1dp">

                    <TextView
                        android:id="@+id/tvIcon2"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:background="@drawable/bg_step_pending"
                        android:gravity="center"
                        android:text="2"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <ProgressBar
                        android:id="@+id/pbStep2"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:indeterminateTint="@color/univalle_red"
                        android:visibility="gone" />

                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvStep2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/host_step2"
                        android:textColor="@color/text_muted_light"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/host_step2_desc"
                        android:textColor="@color/text_muted"
                        android:textSize="11.5sp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Paso 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal">

                <FrameLayout
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginTop="1dp">

                    <TextView
                        android:id="@+id/tvIcon3"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:background="@drawable/bg_step_pending"
                        android:gravity="center"
                        android:text="3"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <ProgressBar
                        android:id="@+id/pbStep3"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:indeterminateTint="@color/univalle_red"
                        android:visibility="gone" />

                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvStep3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/host_waiting"
                        android:textColor="@color/text_muted_light"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/host_step3_desc"
                        android:textColor="@color/text_muted"
                        android:textSize="11.5sp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <TextView
            android:id="@+id/tvInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:textColor="@color/text_muted"
            android:textSize="11.5sp" />

        <!-- Tarjeta de error (oculta hasta que algo falle) -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_status_card_err"
            android:paddingStart="16dp"
            android:paddingTop="11dp"
            android:paddingEnd="14dp"
            android:paddingBottom="11dp"
            android:textColor="@color/err_text"
            android:textSize="13sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/btnCancel"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:text="@string/exit"
            android:textAllCaps="false"
            android:textColor="@color/navy"
            android:textSize="15sp"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            app:strokeColor="@color/line_strong"
            app:strokeWidth="2dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:paddingBottom="12dp"
            android:text="@string/footer_univalle"
            android:textColor="@color/text_muted_light"
            android:textSize="11sp" />

    </LinearLayout>

</LinearLayout>
